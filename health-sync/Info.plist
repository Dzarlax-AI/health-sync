	<array>
		<string>fetch</string>
		<string>processing</string>
	</array>
	<key>UIPrefersShowingLanguageSettings</key>
	<true/>
	<key>CFBundleLocalizations</key>
	<array>
		<string>en</string>
		<string>ru</string>
